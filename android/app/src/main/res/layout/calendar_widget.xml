<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0A0A"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- Navigation Bar with Text Buttons -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentLeft="true"
            android:text="＜"
            android:textColor="#888"
            android:textSize="20sp"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground" />
        <TextView
            android:id="@+id/widget_date_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="APR 2026"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/btn_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentRight="true"
            android:text="＞"
            android:textColor="#888"
            android:textSize="20sp"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground" />
    </RelativeLayout>

    <!-- Weekday Labels: Larger -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="SUN" android:textColor="#ff3b3b" android:textSize="11sp" android:gravity="center" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="MON" android:textColor="#555" android:textSize="11sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TUE" android:textColor="#555" android:textSize="11sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="WED" android:textColor="#555" android:textSize="11sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="THU" android:textColor="#555" android:textSize="11sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="FRI" android:textColor="#555" android:textSize="11sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="SAT" android:textColor="#00e5ff" android:textSize="11sp" android:gravity="center" android:textStyle="bold" />
    </LinearLayout>

    <!-- Grid: No Scrollbars -->
    <GridView
        android:id="@+id/calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:numColumns="7"
        android:verticalSpacing="2dp"
        android:horizontalSpacing="2dp"
        android:stretchMode="columnWidth"
        android:gravity="center"
        android:scrollbars="none"
        android:overScrollMode="never" />
</LinearLayout>
